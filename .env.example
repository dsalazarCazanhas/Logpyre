# Copy this file to .env and fill in your values.
# .env is never committed to version control.

# ── Environment ───────────────────────────────────────────────────────────────
# Controls environment-specific behaviour.
# Accepted values: development | production
# In production: ELASTIC_CERT_FINGERPRINT is required and a default
# FLASK_SECRET_KEY will cause a hard startup failure.
APP_ENV=development

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-string

# ── Elasticsearch connection ──────────────────────────────────────────────────
ELASTIC_HOST=https://127.0.0.1:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=your-elastic-password

# SHA-256 fingerprint of the Elasticsearch TLS certificate.
# Required in production. Optional in development (TLS verification disabled when absent).
# Obtain it with:
#   openssl s_client -connect 127.0.0.1:9200 </dev/null 2>/dev/null \
#     | openssl x509 -noout -fingerprint -sha256
# ELASTIC_CERT_FINGERPRINT=AA:BB:CC:...

# ── Elasticsearch tuning (production) ────────────────────────────────────────
# These have safe defaults for development.
# Review and tune before deploying to production.

# Max simultaneous HTTP connections per Elasticsearch node. Default: 10.
# Increase for high-concurrency deployments (e.g. multiple workers).
# ELASTIC_CONNECTIONS_PER_NODE=10

# Seconds to wait for a response before raising a timeout error. Default: 10.
# Lower for time-sensitive APIs; raise for bulk ingestion workloads.
# ELASTIC_REQUEST_TIMEOUT=10.0

# Retries on failure before raising. Default: 3. Set to 0 to disable.
# Works with retry_on_timeout=True (always enabled).
# ELASTIC_MAX_RETRIES=3
